import tensorflow as tf
import sys
import numpy as np
import scanpy as sc
from sklearn.preprocessing import LabelEncoder
from tensorflow.keras import regularizers

def cell_type_classifier_model(input_dims, output_dims):
    model = tf.keras.Sequential()
    model.add(tf.keras.Input(shape=(input_dims,)))
#     model.add(tf.keras.layers.Dropout(0.1))
#     model.add(tf.keras.layers.Dense(round((input_dims + output_dims) / 2), activation='relu'))
    model.add(tf.keras.layers.Dense(3000, 
                                    kernel_regularizer=regularizers.l1(1e-4),  # L1 regularization
                                    activation='relu'))
    model.add(tf.keras.layers.Dropout(0.1))
#     model.add(tf.keras.layers.Dense(round((input_dims + output_dims) / 4), activation='relu'))
    model.add(tf.keras.layers.Dense(1000, 
                                    kernel_regularizer=regularizers.l1(1e-4),  # L1 regularization
                                    activation='relu'))
    model.add(tf.keras.layers.Dropout(0.1))
    model.add(tf.keras.layers.Dense(output_dims, activation='softmax'))

    model.compile(
                loss=tf.keras.losses.CategoricalCrossentropy(),
              optimizer=tf.keras.optimizers.Adam(learning_rate=0.001),
              metrics=['categorical_accuracy']
    )
    return model
